#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

readonly OMFG_VERSION="0.1.1"
readonly RELEASE_BASE="${OMFG_RELEASE_BASE:-https://omfg.luigiverona.dev/releases}"
readonly EXPECTED_SHA256="${OMFG_RELEASE_SHA256:-}"

die() { printf 'omfg installer: %s\n' "$*" >&2; exit 1; }

[[ ${EUID} -ne 0 ]] || die "do not pipe this installer to a root shell"
[[ -r /etc/os-release ]] || die "cannot identify the operating system"
# shellcheck source=/dev/null
. /etc/os-release
[[ ${ID:-} == arch ]] || die "Arch Linux is required"
[[ $(uname -m) == x86_64 ]] || die "x86_64 architecture is required"
command -v pacman >/dev/null || die "pacman is required"
command -v curl >/dev/null || die "curl is required"
command -v sha256sum >/dev/null || die "sha256sum is required"
command -v tar >/dev/null || die "tar is required"
command -v python >/dev/null || die "Python 3.11 or newer is required"
command -v id >/dev/null || die "id is required"
python -c 'import sys; raise SystemExit(sys.version_info < (3, 11))' || die "Python 3.11 or newer is required"

target_user="$(id -un 2>/dev/null || true)"
[[ -n ${target_user} && ${target_user} != root ]] || die "cannot determine a safe target user"
target_home="$(getent passwd "${target_user}" | cut -d: -f6)"
login_shell="$(getent passwd "${target_user}" | cut -d: -f7)"
[[ -n ${target_home} && ${target_home} != / ]] || die "cannot determine target home"
[[ ${target_home} == "${HOME}" ]] || die "run the installer directly as ${target_user}, not through sudo"

shell_name=""
ancestor_pid="${PPID}"
while [[ -n ${ancestor_pid} && ${ancestor_pid} != 0 ]]; do
  ancestor_comm="$(ps -p "${ancestor_pid}" -o comm= 2>/dev/null | sed 's/^-//' || true)"
  ancestor_args="$(ps -p "${ancestor_pid}" -o args= 2>/dev/null || true)"
  ancestor_tty="$(ps -p "${ancestor_pid}" -o tty= 2>/dev/null | tr -d ' ' || true)"
  case "${ancestor_comm}" in
    fish|bash|zsh)
      case " ${ancestor_args} " in
        *" -c "*|*" -lc "*) ;;
        *)
          if [[ -n ${ancestor_tty} && ${ancestor_tty} != "?" ]]; then
            shell_name="${ancestor_comm}"
            break
          fi
          ;;
      esac
      ;;
  esac
  ancestor_pid="$(ps -p "${ancestor_pid}" -o ppid= 2>/dev/null | tr -d ' ' || true)"
done
if [[ -z ${shell_name} ]]; then
  case "${login_shell##*/}" in
    fish|bash|zsh) shell_name="${login_shell##*/}" ;;
    *) die "the interactive or login shell must be fish, bash, or zsh" ;;
  esac
fi

tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/omfg-bootstrap.XXXXXXXX")"
staging=""
current_stage=""
cleanup() {
  rm -rf -- "${tmp_dir}"
  if [[ -n ${staging} && ${staging} == "${target_home}/.local/share/omfg/releases/.${OMFG_VERSION}.new."* ]]; then
    rm -rf -- "${staging}"
  fi
  if [[ -n ${current_stage} && ${current_stage} == "${target_home}/.local/share/omfg/.current."* ]]; then
    rm -rf -- "${current_stage}"
  fi
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM
archive="${tmp_dir}/omfg-${OMFG_VERSION}.tar.gz"
checksum="${tmp_dir}/omfg-${OMFG_VERSION}.tar.gz.sha256"
release_url="${RELEASE_BASE}/v${OMFG_VERSION}/omfg-${OMFG_VERSION}.tar.gz"

curl -fL --proto '=https' --tlsv1.2 -o "${archive}" "${release_url}"
if [[ -n ${EXPECTED_SHA256} ]]; then
  printf '%s  %s\n' "${EXPECTED_SHA256}" "${archive}" | sha256sum --check --status - || die "release checksum mismatch"
else
  curl -fL --proto '=https' --tlsv1.2 -o "${checksum}" "${release_url}.sha256"
  published="$(awk 'NR == 1 {print $1}' "${checksum}")"
  [[ ${published} =~ ^[0-9a-fA-F]{64}$ ]] || die "invalid release checksum"
  printf '%s  %s\n' "${published}" "${archive}" | sha256sum --check --status - || die "release checksum mismatch"
fi

install_root="${target_home}/.local/share/omfg"
release_dir="${install_root}/releases/${OMFG_VERSION}"
staging="${install_root}/releases/.${OMFG_VERSION}.new.$$"
mkdir -p "${install_root}/releases" "${target_home}/.local/bin"
mkdir "${staging}"
python - "${archive}" "${staging}" <<'PY' || die "release archive is unsafe or invalid"
import copy
import pathlib
import sys
import tarfile

archive = pathlib.Path(sys.argv[1])
destination = pathlib.Path(sys.argv[2]).resolve()
with tarfile.open(archive, "r:gz") as bundle:
    safe = []
    archive_root = None
    for original in bundle.getmembers():
        parts = pathlib.PurePosixPath(original.name).parts
        if not parts or original.name.startswith("/") or ".." in parts:
            raise SystemExit("unsafe archive path")
        if archive_root is None:
            archive_root = parts[0]
        if parts[0] != archive_root:
            raise SystemExit("archive must have one top-level directory")
        if len(parts) == 1:
            if original.isdir():
                continue
            raise SystemExit("archive root must be a directory")
        if not (original.isdir() or original.isfile()):
            raise SystemExit("archive links and special files are not allowed")
        member = copy.copy(original)
        member.name = str(pathlib.PurePosixPath(*parts[1:]))
        target = (destination / member.name).resolve()
        if destination != target and destination not in target.parents:
            raise SystemExit("archive member escapes destination")
        safe.append(member)
    bundle.extractall(destination, members=safe)
PY
[[ -f ${staging}/pyproject.toml && -f ${staging}/src/omfg/cli.py && -d ${staging}/apps && -d ${staging}/deps ]] || die "release archive has an invalid layout"
PYTHONPATH="${staging}/src" python -m omfg --version >/dev/null || die "release application failed validation"
if [[ -d ${release_dir} && ! -L ${release_dir} && -f ${release_dir}/pyproject.toml && -f ${release_dir}/src/omfg/cli.py && -d ${release_dir}/apps && -d ${release_dir}/deps ]]; then
  rm -rf -- "${staging}"
elif [[ -e ${release_dir} || -L ${release_dir} ]]; then
  mv "${release_dir}" "${release_dir}.invalid.$$"
  mv "${staging}" "${release_dir}"
else
  mv "${staging}" "${release_dir}"
fi
current_stage="$(mktemp -d "${install_root}/.current.XXXXXXXX")"
ln -s "releases/${OMFG_VERSION}" "${current_stage}/link"
mv -Tf "${current_stage}/link" "${install_root}/current"
rmdir "${current_stage}"
current_stage=""

launcher="${target_home}/.local/bin/omfg"
launcher_tmp="$(mktemp "${target_home}/.local/bin/.omfg.XXXXXXXX")"
cat >"${launcher_tmp}" <<EOF
#!/bin/sh
export OMFG_CATALOG_ROOT="${install_root}/current"
export PYTHONPATH="${install_root}/current/src"
exec python -m omfg "\$@"
EOF
chmod 0755 "${launcher_tmp}"
mv -Tf "${launcher_tmp}" "${launcher}"

# This line is written literally to the target user's shell file.
# shellcheck disable=SC2016
path_line='case ":$PATH:" in *":$HOME/.local/bin:"*) ;; *) export PATH="$HOME/.local/bin:$PATH" ;; esac'
session_has_path=true
case ":${PATH}:" in *":${target_home}/.local/bin:"*) ;; *) session_has_path=false ;; esac
case "${shell_name}" in
  fish)
    path_file="${target_home}/.config/fish/conf.d/omfg.fish"
    # shellcheck disable=SC2016
    fish_line='fish_add_path --global --move $HOME/.local/bin'
    path_line="${fish_line}"
    ;;
  bash)
    path_file="${target_home}/.bashrc"
    ;;
  zsh)
    path_file="${target_home}/.zshrc"
    ;;
esac
if ! grep -Fqx "${path_line}" "${path_file}" 2>/dev/null; then
  [[ ! -L ${path_file%/*} ]] || die "refusing symbolic shell configuration directory: ${path_file%/*}"
  mkdir -p "${path_file%/*}"
  [[ ! -L ${path_file} ]] || die "refusing to replace symbolic shell configuration: ${path_file}"
  [[ ! -d ${path_file} ]] || die "shell configuration path is a directory: ${path_file}"
  path_tmp="$(mktemp "${path_file}.omfg.XXXXXXXX")"
  if [[ -f ${path_file} ]]; then cat "${path_file}" >"${path_tmp}"; fi
  printf '\n# Added by omfg\n%s\n' "${path_line}" >>"${path_tmp}"
  chmod 0644 "${path_tmp}"
  mv -Tf "${path_tmp}" "${path_file}"
fi

printf 'Omfg %s installed at %s\n' "${OMFG_VERSION}" "${launcher}"
if [[ ${session_has_path} == false ]]; then printf 'A new shell session is required.\n'; fi
printf 'Run omfg when you are ready.\n'
